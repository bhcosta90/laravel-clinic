{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "tallstackui/starter-kit",
    "type": "project",
    "description": "The TallStackUI Starter Kit for Laravel 12.",
    "keywords": [
        "laravel",
        "framework",
        "tallstackui"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Bruno Henrique da Costa",
            "email": "bhcosta90@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0",
        "laravel/telescope": "^5.11",
        "laravel/tinker": "^2.10.1",
        "livewire/livewire": "^3.0.0",
        "owen-it/laravel-auditing": "^14.0",
        "quantumtecnology/controller-basics-extension": "^3.1",
        "stancl/tenancy": "^3.9",
        "tallstackui/tallstackui": "^2.0.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.16",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/breeze": "^2.3",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.21",
        "laravel/sail": "^1.41",
        "lucascudo/laravel-pt-br-localization": "^3.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "rector/rector": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Costa\\Service\\":  "src/src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "Composer\\Config::disableProcessTimeout",
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi",
            "@php artisan db:seed",
            "@composer update"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve --port=8600\" \"php artisan queue:listen --queue='audit,low,high,priority,timeout' --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "format": [
            "./vendor/bin/rector process",
            "./vendor/bin/pint"
        ],
        "analyse": "./vendor/bin/phpstan analyse",
        "test": "./vendor/bin/pest --parallel",
        "ci": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/bin/pint --test",
            "./vendor/bin/phpstan analyse",
            "./vendor/bin/pest --parallel"
        ],
        "reset": [
            "@php artisan tenants:migrate-fresh",
            "@php artisan tenants:seed"
        ],
        "migrate": [
            "@php artisan tenants:migrate"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
